generator client {
  provider = "prisma-client-js"
}

// Dev : SQLite (fichier local, aucune dépendance).
// Production : remplacer provider par "postgresql" et DATABASE_URL par l'URL Postgres.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Valeurs de statut (String pour compatibilité SQLite + Postgres) :
// Token.statut             : ACTIF | UTILISE | REVOQUE
// Stand.statutVote         : FERME | OUVERT
// StaffUser.role           : HOST | ADMIN
// RegistrationCode.statut  : ACTIF | SCANNE | UTILISE | EXPIRE

model StaffUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  nom          String?
  createdAt    DateTime @default(now())

  registeredParticipants Participant[] @relation("RegisteredBy")
}

model Participant {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  fonction  String
  email     String   @unique
  createdAt DateTime @default(now())
  hoteId    String?
  hote      StaffUser? @relation("RegisteredBy", fields: [hoteId], references: [id])

  tokens Token[]
  votes  Vote[]
}

model Token {
  id            String      @id @default(uuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  statut        String      @default("ACTIF")
  createdAt     DateTime    @default(now())
  usedAt        DateTime?

  @@index([participantId, statut])
}

// QR d'enregistrement dynamique affiché à l'accueil : usage unique,
// consommé au scan (ACTIF → SCANNE) puis à l'inscription (→ UTILISE).
model RegistrationCode {
  id            String    @id @default(uuid())
  statut        String    @default("ACTIF")
  createdAt     DateTime  @default(now())
  scannedAt     DateTime?
  participantId String?

  @@index([statut, createdAt])
}

model Stand {
  id          String          @id @default(uuid())
  nom         String
  description String
  tagline     String?
  logoUrl     String?
  color       String?
  initials    String?
  ordre       Int    @default(0)
  statutVote  String @default("FERME")

  votes Vote[]
}

model Vote {
  id            String   @id @default(uuid())
  participantId String
  standId       String
  noteGlobale   Int
  criteres      Json?
  commentaire   String?
  votedAt       DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  stand       Stand       @relation(fields: [standId], references: [id], onDelete: Cascade)

  @@unique([participantId, standId])
}

model Phase {
  id       String   @id @default(uuid())
  titre    String
  horaire  String
  salle    String?
  debut    DateTime?
  fin      DateTime?
  enCours  Boolean  @default(false)
  ordre    Int      @default(0)
}

model EventSettings {
  id             Int     @id @default(1)
  voteOpenGlobal Boolean @default(false)
  votePhase      String  @default("FERME")
}
