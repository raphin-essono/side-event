# Dev : SQLite (fichier local, aucune dépendance)
DATABASE_URL="file:./dev.db"

# Production : PostgreSQL — penser à mettre provider = "postgresql" dans prisma/schema.prisma
# DATABASE_URL="postgresql://user:password@host:5432/vivatech?schema=public"

# Secret de signature des sessions staff — générer une valeur aléatoire forte
SESSION_SECRET="<générer-un-secret-aléatoire>"

# Comptes staff créés par le seed (npm run db:seed) — choisir des identifiants forts
ADMIN_EMAIL="<email-admin>"
ADMIN_PASSWORD="<mot-de-passe-fort>"
HOST_EMAIL="<email-accueil>"
HOST_PASSWORD="<mot-de-passe-fort>"
